# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=AI Orchestration Service
VERSION=0.1.0
ENVIRONMENT=development        # development | staging | production
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# The AI service connects to the same Postgres instance as the NestJS backend
# but owns only its own tables (e.g. pending_actions).
# Driver MUST be asyncpg — do NOT use the plain postgres:// scheme here.
# Mirror the values from backend/.env: DB_USERNAME, DB_PASSWORD, DB_HOST, DB_PORT, DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neurapay-ai-db

# ─── Banking Backend (NestJS) ─────────────────────────────────────────────────
# The AI service NEVER touches the banking DB directly.
# All financial operations go through the NestJS REST API at this URL.
BANKING_BACKEND_URL=http://localhost:3000
BANKING_BACKEND_TIMEOUT_SECONDS=30

# ─── AI Model Provider ────────────────────────────────────────────────────────
# Change MODEL_PROVIDER + MODEL_NAME together to switch providers.
#
#   openai    / gpt-4o-mini                           (recommended)
#   anthropic / anthropic/claude-3-5-haiku-20241022
#   gemini    / gemini/gemini-2.5-flash               (free tier: 20 req/day)
#   groq      / groq/llama-3.1-8b-instant
#   ollama    / ollama/llama3.2                        (local, no API key)
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini

# Only the key matching MODEL_PROVIDER is used — the rest can be left blank.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ─── Agent Behaviour ──────────────────────────────────────────────────────────
AGENTS_MAX_TURNS=10
AGENTS_TRACING_ENABLED=false   # set true to enable OpenAI Agents tracing dashboard

# ─── Transcription Provider ───────────────────────────────────────────────────
# "faster_whisper"  → runs locally on CPU, no API key needed (default)
# "openai_whisper"  → calls OpenAI Whisper API, requires OPENAI_API_KEY above
TRANSCRIPTION_PROVIDER=faster_whisper
MAX_AUDIO_FILE_SIZE_MB=25

# ─── Faster-Whisper (local transcription) ────────────────────────────────────
# Only relevant when TRANSCRIPTION_PROVIDER=faster_whisper
# Model sizes — larger = more accurate, slower first load:
#   tiny | base | small | medium | large-v2 | large-v3
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu              # cpu | cuda
FASTER_WHISPER_COMPUTE_TYPE=int8       # int8 (CPU) | float16 (GPU)
FASTER_WHISPER_LANGUAGE=en             # BCP-47 code, or leave blank for auto-detect
FASTER_WHISPER_VAD_FILTER=true         # strip silence/noise before transcribing
FASTER_WHISPER_INITIAL_PROMPT=Transfer, send money, naira, balance, payment, bill, airtime, account, deposit, withdraw, transaction, recipient, bank.

# ─── OpenAI Whisper (cloud transcription) ────────────────────────────────────
# Only relevant when TRANSCRIPTION_PROVIDER=openai_whisper
OPENAI_WHISPER_MODEL=whisper-1
